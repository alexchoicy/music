{
    "files.exclude": {
        "**/.git": true,
        "**/bin": true,
        "**/obj": true,
        "**/dist": true,
        "**/node_modules": true
    },
    "files.associations": {
        "**/appsettings.json": "jsonc",
        "**/appsettings.Development.json": "jsonc"
    },
    "[csharp]": {
        "editor.defaultFormatter": "csharpier.csharpier-vscode",
        "editor.formatOnSave": true
    }
}