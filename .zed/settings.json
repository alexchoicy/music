{
	"lsp": {
		"oxfmt": {
			"initialization_options": {
				"settings": {
					"fmt.configPath": "./apps/web/.oxfmtrc.json"
				}
			}
		},
		"oxlint": {
			"initialization_options": {
				"settings": {
					"configPath": "./apps/web/.oxlintrc.json",
					"disableNestedConfig": false,
					"fixKind": "safe_fix",
					"run": "onType",
					"unusedDisableDirectives": "deny"
				}
			}
		}
	},
	"languages": {
		"CSS": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"CSharp": {
			"format_on_save": "on",
			"formatter": {
				"external": {
					"command": "dotnet",
					"arguments": ["csharpier", "format"]
				}
			}
		},
		"HTML": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"JavaScript": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"code_action": "source.fixAll.oxc"
				},
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"JSX": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"code_action": "source.fixAll.oxc"
				},
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"JSON": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"JSONC": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"Markdown": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"MDX": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"TypeScript": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"code_action": "source.fixAll.oxc"
				},
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"TSX": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"code_action": "source.fixAll.oxc"
				},
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"YAML": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		}
	},
	"file_scan_exclusions": [
		"**/.bin",
		"**/.git",
		"**/.svn",
		"**/.hg",
		"**/.jj",
		"**/CVS",
		"**/.DS_Store",
		"**/Thumbs.db",
		"**/.classpath", // defaults
		"**/.settings", // projects exclude
		"**/.vscode",
		"**/bin",
		"**/obj",
		"**/.tanstack",
		"**/node_modules",
		"**/.output"
	],
	"file_types": {
		"JSONC": ["appsettings*.json"]
	}
}
